# ╔══════════════════════════════════════════════════════════════════╗
# ║          POLYMARKET TRADING BOT — ENVIRONMENT VARIABLES         ║
# ╚══════════════════════════════════════════════════════════════════╝
#
# HOW TO USE THIS FILE:
#   1. Copy this file and rename it to ".env"
#      (On Mac/Linux: cp .env.example .env)
#      (On Windows:   copy .env.example .env)
#   2. Fill in your values below
#   3. NEVER share your .env file or commit it to Git
#
# The .env file is already in .gitignore so it won't be uploaded.

# ──────────────────────────────────────────────────────────────────
# LIVE TRADING (Required to trade with real money)
# ──────────────────────────────────────────────────────────────────
# Set to "true" to allow LIVE wallets to execute real trades.
# BOTH this variable AND config.yaml must enable live trading.
# Default: false (paper trading only — no real money used)
ENABLE_LIVE_TRADING=false

# ──────────────────────────────────────────────────────────────────
# POLYMARKET CLOB AUTH (Required for LIVE trading)
# ──────────────────────────────────────────────────────────────────
# L1 signer private key used to derive/sign CLOB credentials and orders.
# Use a dedicated trading key. Never share it.
POLYMARKET_PRIVATE_KEY=

# Funder / proxy address that actually holds your Polymarket funds.
# For most Polymarket accounts this is your proxy wallet address.
POLYMARKET_FUNDER_ADDRESS=

# Signature type: 0=EOA, 1=POLY_PROXY, 2=GNOSIS_SAFE (most common)
POLYMARKET_SIGNATURE_TYPE=2

# Polygon mainnet chain id for CLOB trading
POLYMARKET_CHAIN_ID=137

# Optional explicit L2 credentials.
# If omitted, the bot derives credentials from your L1 private key.
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# Optional CLOB base URL override
POLYMARKET_CLOB_API=https://clob.polymarket.com

# ──────────────────────────────────────────────────────────────────
# OPTIONAL SETTINGS
# ──────────────────────────────────────────────────────────────────

# Dashboard port (default: 3000)
# Change this if port 3000 is already in use on your machine.
DASHBOARD_PORT=3000

# Log level: trace | debug | info | warn | error | fatal
# Use "debug" to see more details, "info" for normal operation.
LOG_LEVEL=info

# ──────────────────────────────────────────────────────────────────
# WHALE DATA FETCH TUNING (Optional, useful for RPi/VPN links)
# ──────────────────────────────────────────────────────────────────
# Request timeout in milliseconds for whale-related HTTP fetches.
# Lower value = fail faster, then retry.
SCANNER_FETCH_TIMEOUT_MS=7000

# Retry count for transient whale fetch failures.
SCANNER_FETCH_RETRIES=6

# Exponential backoff base delay in milliseconds.
SCANNER_FETCH_BACKOFF_MS=500

# Upper bound for exponential backoff delay in milliseconds.
SCANNER_FETCH_MAX_BACKOFF_MS=4000

# Gamma markets page size for scanner discovery requests.
# Lower values reduce payload size (can help slow links), but increase total requests.
SCANNER_GAMMA_PAGE_SIZE=50
